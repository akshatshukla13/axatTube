# Monorepo-wide ignore rules for Backend + Frontend

# Dependencies
node_modules/

# Build and coverage output
coverage/
.nyc_output/
dist/
dist-ssr/
build/
.next/
out/
.parcel-cache/
.cache/

# Logs and runtime files
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.pid
*.pid.lock

# Environment and secrets
.env
.env.*
!.env.example
!.env*.example

# Editor and OS files
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# Test artifacts
*.lcov

# Optional package manager/runtime artifacts
.pnpm-store/
.npm/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
.yarn-integrity
.pnp.*
